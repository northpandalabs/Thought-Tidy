{
  "manifest_version": 3,
  "name": "Thought Tidy",
  "version": "1.5.8",
  "description": "AI writing assistant. Fix, rewrite, or transform text in seconds. Works with OpenAI, Claude, Gemini, GitHub Copilot, or Ollama.",
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "512": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Thought Tidy",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "lib/text.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://models.inference.ai.azure.com/*"
  ],
  "optional_host_permissions": [
    "http://127.0.0.1:47391/*",
    "http://127.0.0.1:11434/*",
    "http://localhost:11434/*"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
