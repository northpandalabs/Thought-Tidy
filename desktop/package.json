{
  "name": "thought-tidy-desktop",
  "version": "1.5.8",
  "description": "Thought Tidy — AI writing assistant desktop app (tray + global hotkey)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:test": "electron-builder --config electron-builder-test.yml --publish never",
    "release": "electron-builder --win --publish always",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "build": {
    "appId": "com.northpandalabs.thoughttidy",
    "productName": "Thought Tidy",
    "copyright": "Copyright © 2026 Panda Automation LLC (NorthPanda Labs)",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "main.js",
      "preload.js",
      "ipc-handlers.js",
      "lib-node/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "../lib",
        "to": "lib"
      },
      {
        "from": "../icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Thought Tidy",
      "license": "../legal/eula.txt",
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "northpandalabs",
      "repo": "Thought-Tidy"
    }
  },
  "jest": {
    "reporters": [
      "default",
      "../scripts/commitReporter.js"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "node_modules",
      "dist-build",
      "dist-build-test"
    ],
    "collectCoverageFrom": [
      "lib-node/**/*.js",
      "ipc-handlers.js",
      "!lib-node/updater.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "statements": 70,
        "branches": 60
      }
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0"
  }
}
